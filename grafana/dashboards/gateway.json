{
  "title": "lyqtRpc API Gateway",
  "panels": [
    {
      "title": "QPS by Path",
      "targets": [
        {
          "expr": "rate(gateway_requests_total[1m])",
          "legendFormat": "{{path}} {{method}}"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Latency P50/P90/P99",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(gateway_request_duration_us_bucket[1m]))",
          "legendFormat": "P50 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.90, rate(gateway_request_duration_us_bucket[1m]))",
          "legendFormat": "P90 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(gateway_request_duration_us_bucket[1m]))",
          "legendFormat": "P99 {{path}}"
        }
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Error Rate %",
      "targets": [
        {
          "expr": "rate(gateway_errors_total[1m]) / rate(gateway_requests_total[1m]) * 100",
          "legendFormat": "{{path}} code={{code}}"
        }
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "title": "Circuit Breaker + Rate Limit",
      "targets": [
        {
          "expr": "circuit_breaker_state",
          "legendFormat": "breaker {{method}}@{{host}}"
        },
        {
          "expr": "rate(rpc_rate_limited_total[1m])",
          "legendFormat": "rate-limited/s"
        },
        {
          "expr": "rpc_connection_count",
          "legendFormat": "connections"
        }
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    }
  ]
}
